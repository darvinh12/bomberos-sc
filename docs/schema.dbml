// OPS — operaciones
// =============================================================================
Table ops.guardias {
  id bigint [pk, increment]
  fecha date [not null]
  estacion_id smallint [not null, ref: > org.estaciones.id]
  seccion varchar(1)
  turno text [not null]
  hora_inicio time [not null]
  hora_fin time [not null]
  jefe_guardia_id bigint [ref: > personal.funcionarios.id]
  cerrada boolean
  cerrada_at timestamptz

  indexes { (fecha, estacion_id, seccion, turno) [unique] }
}

Table ops.guardia_funcionarios {
  id bigint [pk, increment]
  guardia_id bigint [not null, ref: > ops.guardias.id]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  rol_guardia text
  asistio boolean
  motivo_inasistencia text
