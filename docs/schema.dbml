  autorizado_at timestamptz
  documento_url text
}

Table ops.solicitudes_permiso {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  fecha_inicio date [not null]
  fecha_fin date [not null]
  motivo text [not null]
  estatus estatus_solicitud
  permiso_id bigint [ref: > ops.permisos.id]
}

Table ops.vacaciones {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  periodo_anio smallint [not null]
  fecha_inicio date [not null]
  fecha_fin date [not null]
  dias_habiles smallint
  dias_calendario smallint [note: 'GENERATED']
