Table egresos.fallecimientos {
  id bigint [pk, increment]
  funcionario_id bigint [unique, not null, ref: > personal.funcionarios.id]
  fecha_fallecimiento date [not null]
  en_servicio boolean
  causa text
  lugar text
  acta_defuncion text
  beneficio_funerario_pagado boolean
}

// =============================================================================
// DOCUMENTOS
// =============================================================================
Table documentos.acervo {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  tipo_documento_id smallint [not null, ref: > core.tipos_documento.id]
  titulo text [not null]
  numero text
  referencia text
  fecha_documento date
  documento_url text
  tamano_bytes bigint
  hash_sha256 text
  created_by bigint [ref: > seguridad.usuarios.id]
}

Table documentos.oficios {
  id bigint [pk, increment]
  numero text [unique, not null]
  fecha date [not null]
  tipo text [not null]
  asunto text [not null]
  cuerpo text
  remitente_id bigint [ref: > personal.funcionarios.id]
  archivado boolean
}

Table documentos.oficios_destinatarios {
  id bigint [pk, increment]
  oficio_id bigint [not null, ref: > documentos.oficios.id]
  funcionario_id bigint [ref: > personal.funcionarios.id]
  institucion_id bigint [ref: > core.instituciones.id]
  nombre_libre text
  es_copia boolean
}

Table documentos.actas {
  id bigint [pk, increment]
  numero text [not null]
  fecha date [not null]
  tipo text
  lugar text
  motivo text
  resumen text
  acuerdos text

  indexes { (numero, fecha, tipo) [unique] }
}

Table documentos.actas_asistentes {
  id bigint [pk, increment]
  acta_id bigint [not null, ref: > documentos.actas.id]
  funcionario_id bigint [ref: > personal.funcionarios.id]
  nombre_libre text
  rol text
  firmo boolean
}

Table documentos.firmas_autorizadas {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  cargo_firma text [not null]
  contexto text
  fecha_inicio date [not null]
  fecha_fin date
  activa boolean [default: true]
  firma_url text
  sello_url text
}

// =============================================================================
// AUD — auditoría
// =============================================================================
Table aud.log_cambios {
  id bigint [pk, increment]
  schema_name text [not null]
  table_name text [not null]
  registro_id text
  operacion operacion_audit
  valor_anterior text [note: 'JSONB']
  valor_nuevo text [note: 'JSONB']
  campos_cambiados text [note: 'JSONB']
  usuario_id bigint
  usuario_nombre text
  ip text
  fecha timestamptz
}

Table aud.log_accesos {
  id bigint [pk, increment]
  usuario_id bigint [ref: > seguridad.usuarios.id]
  usuario citext
  ip text
  user_agent text
  sistema_op text
  navegador text
  tipo_evento tipo_evento_acceso
  detalle text
  fecha timestamptz
}

// =============================================================================
// FIN
// =============================================================================
