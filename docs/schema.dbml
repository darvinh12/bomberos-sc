// =============================================================================
// CUERPO DE BOMBEROS DE CARACAS — Modelo de datos en DBML
// Para visualizar:  https://dbdiagram.io/d  →  File → Import → DBML
// Fuente de verdad: ../sql/01_base.sql + ../sql/02_dominio.sql
// =============================================================================

Project bomberos_caracas {
  database_type: 'PostgreSQL'
  Note: 'Sistema integrado del Cuerpo de Bomberos del Distrito Capital. v2.0.0'
}

// =============================================================================
// ENUMS
// =============================================================================
Enum estatus_funcionario {
  ACTIVO
  REPOSO
  COMISION
  PRE_JUBILADO
  JUBILADO
  EGRESADO
  FALLECIDO
  SUSPENDIDO
  BAJA_DESHONROSA
  PERMISO_LARGO
}

Enum tipo_personal {
  BOMBERO
  BOMBERO_VOLUNTARIO
  OBRERO
  EMPLEADO
  CONTRATADO
  PASANTE
}

Enum estatus_solicitud {
  PENDIENTE
  EN_PROCESO
  APROBADO
  RECHAZADO
  ARCHIVADO
  PAGADO
  ENTREGADO
  ANULADO
}

Enum tipo_actividad {
  CULTURAL
  DEPORTIVA
  MUSICAL
  CIENTIFICA
  LABORAL
  ACADEMICA
}

Enum tipo_movimiento_inventario {
  INGRESO
  EGRESO
  AJUSTE
  TRANSFERENCIA
  BAJA
  DEVOLUCION
}

Enum tipo_evento_acceso {
  LOGIN
  LOGOUT
  LOGIN_FALLIDO
  BLOQUEO
  CAMBIO_PASSWORD
  PASSWORD_RESET
}

Enum operacion_audit {
  I
  U
  D
}

// =============================================================================
// CORE — catálogos compartidos
// =============================================================================
Table core.estados_civiles {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  activo boolean [default: true]
}

Table core.grupos_sanguineos {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
}

Table core.niveles_educativos {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  orden smallint [default: 0]
}

Table core.tipos_nivel_educativo {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
}

Table core.especialidades {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  descripcion text
  activo boolean [default: true]
}

Table core.jerarquias {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  nombre_corto text
  orden smallint [default: 0]
  es_oficial boolean
  es_tropa boolean
  es_estado_mayor boolean
  activo boolean [default: true]
}

Table core.cargos {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  es_jefatura boolean
  activo boolean [default: true]
}

Table core.condiciones {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  activo boolean [default: true]
}

Table core.tipos_reposo {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  dias_max smallint
  requiere_diagnostico boolean
}

Table core.tipos_solicitud {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  monto_max numeric(15,2)
}

Table core.tipos_documento {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
}

Table core.tipos_carnet {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
}

Table core.tipos_licencia {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
}

Table core.tipos_accidente {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
}

Table core.tallas {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  grupo text [not null]
  orden smallint
}

Table core.bancos {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  swift text
  activo boolean [default: true]
}

Table core.proveedores {
  id bigint [pk, increment]
  rif text [unique]
  razon_social text [not null]
  nombre_comercial text
  rubro text
  activo boolean [default: true]
}

Table core.instituciones {
  id bigint [pk, increment]
  codigo text [unique]
  nombre text [not null]
  siglas text
  activo boolean [default: true]
}

// =============================================================================
// GEO
// =============================================================================
Table geo.estados {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  capital text
}

Table geo.municipios {
  id int [pk, increment]
  estado_id smallint [not null, ref: > geo.estados.id]
  codigo text [not null]
  nombre text [not null]

  indexes { (estado_id, codigo) [unique] }
}

Table geo.parroquias {
  id int [pk, increment]
  municipio_id int [not null, ref: > geo.municipios.id]
  codigo text [not null]
  nombre text [not null]

  indexes { (municipio_id, codigo) [unique] }
}

// =============================================================================
// ORG — estructura organizacional
// =============================================================================
Table org.zonas {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  activo boolean [default: true]
}

Table org.estaciones {
  id smallint [pk, increment]
  zona_id smallint [not null, ref: > org.zonas.id]
  parroquia_id int [ref: > geo.parroquias.id]
  codigo text [unique, not null]
  nombre text [not null]
  nombre_corto text
  direccion text
  latitud numeric(10,7)
  longitud numeric(10,7)
  activa boolean [default: true]
}

Table org.divisiones {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  activo boolean [default: true]
}

Table org.areas {
  id smallint [pk, increment]
  division_id smallint [ref: > org.divisiones.id]
  codigo text [unique, not null]
  nombre text [not null]
  activo boolean [default: true]
}

Table org.dependencias {
  id smallint [pk, increment]
  area_id smallint [ref: > org.areas.id]
  codigo text [unique, not null]
  nombre text [not null]
  activo boolean [default: true]
}

Table org.areas_operativas {
  area_id smallint [ref: > org.areas.id]
  dependencia_id smallint [ref: > org.dependencias.id]

  indexes { (area_id, dependencia_id) [pk] }
}

Table org.jefes_area_zona {
  id bigint [pk, increment]
  zona_id smallint [ref: > org.zonas.id]
  area_id smallint [ref: > org.areas.id]
  funcionario_id bigint [not null]
  cargo_id smallint [ref: > core.cargos.id]
  fecha_inicio date [not null]
  fecha_fin date
  activo boolean [default: true]
}

// =============================================================================
// SYS
// =============================================================================
Table sys.parametros {
  id int [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  valor text [not null]
  tipo_dato text
  descripcion text
  editable boolean
  sensible boolean
  grupo text
}

Table sys.versiones {
  id bigint [pk, increment]
  version text [not null]
  aplicada_at timestamptz
  descripcion text
}

Table sys.feriados {
  id int [pk, increment]
  fecha date [not null]
  nombre text [not null]
  es_nacional boolean
}

// =============================================================================
// SEGURIDAD
// =============================================================================
Table seguridad.roles {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  descripcion text
  es_sistema boolean
  activo boolean [default: true]
}

Table seguridad.modulos {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
  orden smallint
  activo boolean [default: true]
}

Table seguridad.rol_permisos {
  rol_id smallint [ref: > seguridad.roles.id]
  modulo_id smallint [ref: > seguridad.modulos.id]
  puede_ver boolean
  puede_crear boolean
  puede_editar boolean
  puede_eliminar boolean
  puede_exportar boolean
  puede_aprobar boolean

  indexes { (rol_id, modulo_id) [pk] }
}

Table seguridad.usuarios {
  id bigint [pk, increment]
  funcionario_id bigint
  usuario citext [unique, not null]
  password_hash text [not null]
  nombre_completo text [not null]
  correo citext [unique]
  activo boolean [default: true]
  bloqueado boolean
  motivo_bloqueo text
  intentos_fallidos smallint
  debe_cambiar_password boolean
  mfa_activo boolean
  mfa_secret text
  ultimo_acceso timestamptz
  ultimo_ip inet
  created_at timestamptz
  updated_at timestamptz
  created_by bigint [ref: > seguridad.usuarios.id]
  updated_by bigint [ref: > seguridad.usuarios.id]
}

Table seguridad.usuario_roles {
  usuario_id bigint [ref: > seguridad.usuarios.id]
  rol_id smallint [ref: > seguridad.roles.id]
  asignado_at timestamptz
  asignado_por bigint [ref: > seguridad.usuarios.id]

  indexes { (usuario_id, rol_id) [pk] }
}

Table seguridad.usuario_permisos {
  usuario_id bigint [ref: > seguridad.usuarios.id]
  modulo_id smallint [ref: > seguridad.modulos.id]
  puede_ver boolean
  puede_crear boolean
  puede_editar boolean
  puede_eliminar boolean
  puede_exportar boolean
  puede_aprobar boolean

  indexes { (usuario_id, modulo_id) [pk] }
}

Table seguridad.usuario_scopes {
  id bigint [pk, increment]
  usuario_id bigint [not null, ref: > seguridad.usuarios.id]
  zona_id smallint [ref: > org.zonas.id]
  estacion_id smallint [ref: > org.estaciones.id]
  division_id smallint [ref: > org.divisiones.id]
  area_id smallint [ref: > org.areas.id]
}

Table seguridad.sesiones {
  id uuid [pk]
  usuario_id bigint [not null, ref: > seguridad.usuarios.id]
  token_hash text [unique, not null]
  ip inet
  user_agent text
  creada_at timestamptz
  expira_at timestamptz
  cerrada_at timestamptz
}

// =============================================================================
// PERSONAL
// =============================================================================
Table personal.funcionarios {
  id bigint [pk, increment]
  nacionalidad varchar(1) [not null, note: 'V o E']
  cedula int [not null]
  rif text
  apellidos text [not null]
  nombres text [not null]
  nombre_completo text [note: 'GENERATED']
  fecha_nacimiento date
  sexo varchar(1)
  estado_civil_id smallint [ref: > core.estados_civiles.id]
  grupo_sanguineo_id smallint [ref: > core.grupos_sanguineos.id]
  lugar_nacimiento text
  pais_nacimiento text
  tipo_personal tipo_personal
  numero_empleado text [unique]
  numero_equipo text [note: 'snapshot — historial en historico_numeros_equipo']
  fecha_primer_ingreso date [note: 'inmutable; ciclos en periodos_servicio']
  promocion text
  estatus estatus_funcionario
  condicion_id smallint [ref: > core.condiciones.id, note: 'snapshot — historial en historico_condiciones']
  jerarquia_id smallint [ref: > core.jerarquias.id]
  cargo_id smallint [ref: > core.cargos.id]
  zona_id smallint [ref: > org.zonas.id]
  estacion_id smallint [ref: > org.estaciones.id]
  area_id smallint [ref: > org.areas.id]
  dependencia_id smallint [ref: > org.dependencias.id]
  division_id smallint [ref: > org.divisiones.id]
  seccion varchar(1)
  horario text
  telefono_habitacion text
  telefono_movil text
  telefono_otros text
  correo citext [unique]
  persona_contacto text
  telefono_contacto text
  parentesco_contacto text
  nivel_educativo_id smallint [ref: > core.niveles_educativos.id]
  profesion text
  especialidad_id smallint [ref: > core.especialidades.id]
  iutb boolean
  egresado_unes boolean
  foto_url text
  huella_url text
  firma_url text
  merito numeric(5,2)
  pre_jubilado boolean
  es_voluntario boolean
  observaciones text
  created_at timestamptz
  updated_at timestamptz
  created_by bigint [ref: > seguridad.usuarios.id]
  updated_by bigint [ref: > seguridad.usuarios.id]

  indexes {
    (nacionalidad, cedula) [unique, name: 'funcionarios_cedula_uq']
    apellidos
    estatus
    nombre_completo [name: 'gin_trgm']
  }
}

Ref: seguridad.usuarios.funcionario_id > personal.funcionarios.id
Ref: org.jefes_area_zona.funcionario_id > personal.funcionarios.id

Table personal.periodos_servicio {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  numero_periodo smallint [not null]
  fecha_ingreso date [not null]
  fecha_egreso date [note: 'NULL = activo']
  tipo_ingreso text [note: 'INGRESO / REINGRESO / REINCORPORACION']
  tipo_egreso text [note: 'RENUNCIA / DESPIDO / JUBILACION / etc.']
  motivo text
  base_legal text
  numero_resolucion text
  nro_memo text
  fecha_notificacion date
  fecha_efectiva_nomina date
  pagaron_prestaciones boolean
  monto_prestaciones numeric(15,2)
  documento_url text
  observaciones text
  created_at timestamptz
  updated_at timestamptz

  indexes {
    (funcionario_id, numero_periodo) [unique]
    funcionario_id
  }
}

Table personal.historico_condiciones {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  condicion_id smallint [not null, ref: > core.condiciones.id]
  fecha_inicio date [not null]
  fecha_fin date
  motivo text
  resolucion text
  documento_url text
}

Table personal.historico_numeros_equipo {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  numero_equipo text [not null]
  fecha_inicio date [not null]
  fecha_fin date
  motivo text
}

Table personal.cuentas_bancarias {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  banco_id smallint [not null, ref: > core.bancos.id]
  numero_cuenta text [not null]
  tipo_cuenta varchar(1)
  titular text
  es_actual boolean [default: true]
  fecha_alta date
  fecha_baja date
}

Table personal.licencias_conducir {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  tipo_licencia_id smallint [not null, ref: > core.tipos_licencia.id]
  numero text
  fecha_emision date [not null]
  fecha_vence date
  organismo text
  es_actual boolean [default: true]
  documento_url text
}

Table personal.direcciones {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  es_actual boolean
  estado_id smallint [ref: > geo.estados.id]
  municipio_id int [ref: > geo.municipios.id]
  parroquia_id int [ref: > geo.parroquias.id]
  sector text
  urbanizacion text
  calle text
  edificio_casa text
  piso text
  apartamento text
  referencia text
  direccion_completa text
  codigo_postal text
  latitud numeric(10,7)
  longitud numeric(10,7)
  es_propia boolean
  es_alquilada boolean
  fecha_registro date
}

Table personal.carga_familiar {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  parentesco text [not null]
  nacionalidad varchar(1)
  cedula int
  apellidos text [not null]
  nombres text [not null]
  fecha_nacimiento date
  sexo varchar(1)
  estado_civil_id smallint [ref: > core.estados_civiles.id]
  nivel_educativo_id smallint [ref: > core.niveles_educativos.id]
  estudia boolean
  trabaja boolean
  discapacidad boolean
  es_beneficiario_hcm boolean
  activo boolean [default: true]
  fecha_inclusion date
  fecha_baja date
}

Table personal.educacion {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  nivel_id smallint [not null, ref: > core.niveles_educativos.id]
  tipo_id smallint [ref: > core.tipos_nivel_educativo.id]
  titulo text
  institucion text
  pais text
  fecha_inicio date
  fecha_fin date
  fecha_titulo date
  documento_url text
}

Table personal.habilidades {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  grupo text [not null]
  nombre text [not null]
  nivel text
  certificado boolean
}

Table personal.actividades {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  tipo tipo_actividad
  nombre text [not null]
  descripcion text
  institucion text
  fecha_inicio date
  fecha_fin date
}

Table personal.tiempo_admpublica {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  institucion text [not null]
  cargo text
  fecha_inicio date [not null]
  fecha_fin date
  documento_url text
}

Table personal.carnets {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  tipo_carnet_id smallint [not null, ref: > core.tipos_carnet.id]
  numero text
  serial text
  codigo_qr text
  fecha_emision date
  fecha_vence date
  organismo_emisor text
  documento_url text
  activo boolean [default: true]
}

Table personal.historico_carnets {
  id bigint [pk, increment]
  carnet_id bigint [not null, ref: > personal.carnets.id]
  numero_anterior text
  numero_nuevo text
  motivo text
  fecha date
  usuario_id bigint [ref: > seguridad.usuarios.id]
}

Table personal.carnets_vehiculo {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  placa text [not null]
  marca text
  modelo text
  anio smallint
  color text
  serial_carroceria text
  serial_motor text
  tipo_vehiculo text
  fecha_emision date
  fecha_vence date
  documento_url text
  activo boolean [default: true]
}

Table personal.registro_votacion {
  id bigint [pk, increment]
  funcionario_id bigint [unique, not null, ref: > personal.funcionarios.id]
  centro_electoral text
  parroquia_id int [ref: > geo.parroquias.id]
  municipio_id int [ref: > geo.municipios.id]
  estado_id smallint [ref: > geo.estados.id]
  mesa text
}

Table personal.hogares_patria {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  serial_carnet_patria text
  codigo_hogar text
  cantidad_personas smallint
  cantidad_menores smallint
  cantidad_adultos_mayores smallint
  es_jefe_hogar boolean
  recibe_clap boolean
  recibe_bono boolean
  direccion text
  parroquia_id int [ref: > geo.parroquias.id]
  fecha_registro date
}

Table personal.gdc_habitacional {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  codigo_postulacion text
  programa text
  estado text
  proyecto text
  parroquia_id int [ref: > geo.parroquias.id]
  fecha_postulacion date
  fecha_adjudicacion date
  fecha_entrega date
}

Table personal.historico_jerarquias {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  jerarquia_id smallint [not null, ref: > core.jerarquias.id]
  fecha_inicio date [not null]
  fecha_fin date
  motivo text
  resolucion text
  documento_url text
}

Table personal.historico_ubicaciones {
  id bigint [pk, increment]
  funcionario_id bigint [not null, ref: > personal.funcionarios.id]
  zona_id smallint [ref: > org.zonas.id]
  estacion_id smallint [ref: > org.estaciones.id]
  area_id smallint [ref: > org.areas.id]
  dependencia_id smallint [ref: > org.dependencias.id]
  division_id smallint [ref: > org.divisiones.id]
  cargo_id smallint [ref: > core.cargos.id]
  fecha_inicio date [not null]
  fecha_fin date
  motivo text
  resolucion text
}

Table personal.postulados {
  id bigint [pk, increment]
  nacionalidad varchar(1) [not null]
  cedula int [not null]
  apellidos text [not null]
  nombres text [not null]
  fecha_nacimiento date
  sexo varchar(1)
  telefono text
  correo citext
  direccion text
  nivel_educativo_id smallint [ref: > core.niveles_educativos.id]
  fecha_postulacion date
  estatus estatus_solicitud
  promocion_destino text
  nota_examen_fisico numeric(5,2)
  nota_examen_medico numeric(5,2)
  nota_examen_psico numeric(5,2)
  nota_examen_acad numeric(5,2)
  aprobado boolean
  funcionario_id bigint [ref: > personal.funcionarios.id]

  indexes { (nacionalidad, cedula) [unique] }
}

// =============================================================================
// SALUD
// =============================================================================
Table salud.grupos_diagnosticos {
  id smallint [pk, increment]
  codigo text [unique, not null]
  nombre text [not null]
}

Table salud.diagnosticos {
  id int [pk, increment]
  codigo_cie text [unique]
  grupo_id smallint [ref: > salud.grupos_diagnosticos.id]
  nombre text [not null]
  descripcion text
  activo boolean [default: true]
}

Table salud.medicos {
  id bigint [pk, increment]
  nacionalidad varchar(1)
  cedula int
  apellidos text [not null]
  nombres text [not null]
  nombre_completo text
  mpps text [unique]
  cm text
  especialidad text
  telefono text
  correo citext
  activo boolean [default: true]

  indexes { (nacionalidad, cedula) [unique] }
}

Table salud.centros_medicos {
  id bigint [pk, increment]
  rif text [unique]
  nombre text [not null]
  tipo text
  direccion text
