# Copiar a .env y ajustar valores
APP_ENV=development
APP_NAME=bomberos-api
APP_DEBUG=true

# Base de datos
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bomberos_caracas

# Seguridad
JWT_SECRET_KEY=cambiar-esto-en-produccion-debe-ser-largo-y-aleatorio
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (separado por comas)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting
RATE_LIMIT_PER_MINUTE=120

# Logs
LOG_LEVEL=INFO
LOG_FORMAT=json

# Bootstrap (solo se usa al primer arranque en producción)
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=admin@bomberos.gob.ve

# Workers de uvicorn (Railway/Render)
WEB_CONCURRENCY=2

# Almacenamiento local (intranet on-premise, sin acceso a internet).
# Carpeta raíz para fotos, huellas, firmas y documentos.
STORAGE_PATH=./data/uploads
